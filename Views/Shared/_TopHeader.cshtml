    $(document).ready(function () {
        //Show then hide ddown menu on hover
        $('.menuitem').hover(function () {
            $(this).children('.navmain').slideDown(500);
        }, function () {
            $(this).children('.navmain').slideUp(500);
        });
    });
</script>
