@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor Accessor

<div class="row form-group">
    <div class="col-md-3">
        <lable class="label-control">APR Code</lable>

        <input type="text" hidden id="AccountPricing_status" />

        @*<input type="text" id="txt_APRCode" onkeypress='return isNumberOnlyKey(event)' class="form-control custom-form-control" placeholder="Enter" />*@

        <input type="text" id="txt_APRCode" class="form-control custom-form-control" placeholder="Enter" />

    </div>
    <div class="col-md-1 mt-20">
        <button id="btn_APR_Details" class="btn btn-primary btn-fetch"><i class="fa fa-chevron-right"></i></button>
    </div>
    <div class="col-md-2">
        <lable class="label-control">PFY APR</lable>
        <input type="text" class="form-control custom-form-control" disabled id="txt_PFY" />

    </div>
    <div class="col-md-3">
        <lable class="label-control">YTD APR</lable>
        <input type="text" class="form-control custom-form-control" disabled id="txt_YTD" />
    </div>
    <div class="col-md-3">
        <lable class="label-control">Client ID</lable>
        <input type="text" class="form-control custom-form-control" id="txt_ClientId_AC" />
    </div>
</div>
<div class="row form-group">
    <div class="col-md-3">
        <lable class="label-control">Customer Name</lable>
        <input type="text" id="txt_AC_CustomerName" class="form-control custom-form-control" placeholder="Enter" />

    </div>

    <div class="col-md-3">
        <lable class="label-control">Account number</lable>
        <input type="text" id="txt_AC_AccountNo" maxlength="16" onkeypress='return isNumberOnlyKey(event)' class="form-control custom-form-control" placeholder="Enter" />
        <input type="hidden" id="AccountCustomization_CustomerId" />
        <input type="hidden" id="createdById" />
    </div>
    <div class="col-md-3">
        <lable class="label-control">Product Code</lable>
        <input type="text" id="txt_ProductCode" onkeypress="return blockSpecialChar(event)" class="form-control custom-form-control" placeholder="Enter" />
    </div>

</div>

<div class="row form-group">
    <div id="accountcustomization" class="accordion accordion-no-gutter accordion-bordered">
        <div class="accordion__item">
            <div class="accordion__header collapsed style_two" data-toggle="collapse" data-target="#bordered_no-gutter_collapseOne">
                <span class="accordion__header--text">
                    WAIVER Details
                </span>
                <span class="accordion__header--indicator"></span>
            </div>
            <div id="bordered_no-gutter_collapseOne" class="collapse accordion__body show" data-parent="#accountcustomization">
                <div class="accordion__body--text">
                    <div class="row form-group">
                        <div class="col-md-12">
                            <div class="table-outer">
                                <table class="responsive-table" id="tbl_waiverDetails">
                                    <thead>
                                        <tr>
                                            <th scope="col">Charge Type</th>
                                            <th scope="col">Type of waiver</th>
                                            <th scope="col">Values (In Rs)</th>
                                            <th scope="col">No. of txn</th>
                                            <th scope="col">AMB Commitment</th>
                                            <th>Action</th>
                                        </tr>

                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <button id="btnAddWaiver" class="dynamic-control-add">+  Add Waivers</button>
                        </div>
                        <div class="col-md-6">
                            <button class="btn btn-primary" style="float:right;width:13%;padding:3px 0;font-size:14px;" id="btn_save_waiverDetails">Save</button>
                        </div>
                    </div>
                    <div class="row form-group">
                        <div class="col-md-12">
                            <div class="table-outer">
                                <table class="responsive-table" style="display:none" id="tbl_waiverTemp">
                                    @*<thead>
                                    <tr>
                                    <th scope="col">Customer Name</th>
                                    <th scope="col">Account No.</th>
                                    <th scope="col">No. Of Charges</th>
                                    <th scope="col">Value(in lac(s))</th>
                                    <th scope="col">Action</th>
                                    </tr>
                                    </thead>
                                    <tbody></tbody>*@
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

