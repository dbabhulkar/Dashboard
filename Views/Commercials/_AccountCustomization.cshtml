<div class="row mb-5">
    <div class="col-md-5">
        <label class="label-control">Document</label>
        <div class="fileUpload blue-btn btn width100">
            <i class="fa fa-upload"></i><div class="file-name"></div>
            <input type="file" id="documentupload" class="logoUpload" accept=".csv,.xlsx,.xlsm,.xls,.pdf">
        </div>
        @*<label  class="label-control">Justification</label>*@
        @*<a id="txt_document"  class="form-control custom-form-control"></a>*@
        <input type="text" style="height:20px; font-size:13px" readonly id="txt_document" class="form-control custom-form-control" />
        <button type="submit" id="doc_download" class="btn_downloads">
            <i class="fa fa-download"></i>
        </button>
    </div>

</div>
<div class="row form-group">
    <div class="col-md-8">
        <label class="label-control" style="font-size:12px;">Justification</label>
        @*<input type="text" id="txt_justification" class="form-control custom-form-control" placeholder="Enter" />*@
        <textarea id="txt_justificationAccountCustom" rows="5" class="form-control custom-form-control" placeholder="Enter.."></textarea>
    </div>
</div>
<div class="row form-group">
    <div class="col-md-3">
        <div class="form-group">
            <label class="label-control" style="display:inline-block">Cluster Head (L1)</label>
            <select class="form-control custom-form-control" id="AC_DropDown_Level1" multiple></select>
        </div>
    </div>

    <div class="col-md-3">
        <div class="form-group">
            <label class="label-control" style="display:inline-block">Circle Head (L2)</label>
            <select class="form-control custom-form-control" id="AC_DropDown_Level2" multiple></select>
        </div>
    </div>
    <div class="col-md-3">
        <div class="form-group">
            <label class="label-control" style="display:inline-block">State Head (L3)</label>
            <select class="form-control custom-form-control" id="AC_DropDown_Level3" multiple></select>
        </div>
    </div>
    <div class="col-md-3">
        <div class="form-group">
            <label class="label-control" style="display:inline-block">Regional Head (L4)</label>
            <select class="form-control custom-form-control" id="AC_DropDown_Level4" multiple></select>
        </div>
    </div>
    <div class="col-md-3">
        <div class="form-group">
            <label class="label-control" style="display:inline-block">Zonal Head (L5)</label>
            <select class="form-control custom-form-control" id="AC_DropDown_Level5" multiple></select>
        </div>
    </div>
    <div class="col-md-3">
        <div class="form-group">
            <label class="label-control" style="display:inline-block">Business Head (L6)</label>
            <select class="form-control custom-form-control" id="AC_DropDown_Level6" multiple></select>
        </div>
    </div>
    <div class="col-md-3">
        <div class="form-group">
            <label class="label-control" style="display:inline-block">Group Head (L7)</label>
            <select class="form-control custom-form-control" id="AC_DropDown_Level7" multiple></select>
        </div>
    </div>
</div>
<div class="row">

    @if (@Accessor.HttpContext.Session.GetString("UserRole") == "Relationship Manager")
    {
        <div class="col-md-3" style="margin-top: 15px;">
            <button class="btn btn-primary" id="btn_accountsubmit">Submit</button>
        </div>
    }
    else
    {
        <div class="col-md-6" style="margin-top: 15px;">
            <button class="btn btn-success" id="btn_approveAccountCustomisation" data-toggle="modal" data-target="#ApproveModalAccountCustomisation">Approve</button>
            <button class="btn btn-warning" id="btn_sendbackAccountCustomisation" data-toggle="modal" data-target="#SendBackModalAccountCustomisation">Send Back</button>
            <button class="btn btn-danger" id="btn_RejectAccountCustomisation" data-toggle="modal" data-target="#RejectModalAccountCustomisation">Reject</button>
        </div>

    }
</div>

<div class="modal fade" id="ApproveModalAccountCustomisation" tabindex="-1" aria-labelledby="ApproveModalAccountCustomisation" aria-hidden="true">
    <div class="modal-dialog modal-sm" style="max-width: 610px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Add Approve Remark</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="label-control">Remark</label>
                    <textarea class="form-control" id="txt_approve_remark_AccountCustomisation" required rows="5"></textarea>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="submit" id="BtnApproveAccountCustomisation" class="btn btn-info">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="RejectModalAccountCustomisation" tabindex="-1" aria-labelledby="RejectModalAccountCustomisation" aria-hidden="true">
    <div class="modal-dialog modal-sm" style="max-width: 610px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Add Reject Remark</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="label-control">Remark</label>
                    <textarea class="form-control" id="txt_reject_remark_AccountCustomisation" required rows="5"></textarea>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="submit" id="BtnRejectAccountCustomisation" class="btn btn-info">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="SendBackModalAccountCustomisation" tabindex="-1" aria-labelledby="SendBackModalAccountCustomisation" aria-hidden="true">
    <div class="modal-dialog modal-sm" style="max-width: 610px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Add Send Back Remark</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="label-control">Remark</label>
                    <textarea class="form-control" id="txt_sendback_remark_AccountCustomisation" required rows="5"></textarea>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="submit" id="BtnSendBackAccountCustomisation" class="btn btn-info">Save</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/account-customization.js"></script>