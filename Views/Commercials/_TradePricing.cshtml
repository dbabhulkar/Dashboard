        <input type="text" id="txt_tradeAprcode" onkeypress='return TradeAPRCodeValidate()' class="form-control custom-form-control" placeholder="Enter" />
    </div>
    <div class="col-md-1 mt-20 rblexisting" id="BtnGetCustomerInfo_dv" style="display:none">
        <button id="BtnGetCustomerInfo" class="btn btn-primary btn-fetch"><i class="fa fa-chevron-right"></i></button>
    </div>
    <div class="col-md-3">
        <lable class="label-control">Customer Name</lable>
        <input type="text" class="form-control custom-form-control" id="txtCutomerName" placeholder="Enter" />
        <input type="text" hidden id="TradePricing_CustomerId" />
        <input type="text" hidden id="TradePricing_status" />
    </div>
    <div class="col-md-3">
        <lable class="label-control">PAN Number</lable>
        <input type="text" maxlength="16" class="form-control custom-form-control" onkeypress="return blockSpecialChar(event)" id="txtPanNo" placeholder="Enter" />

        @*<input type="text" maxlength="16" class="form-control custom-form-control" style="text-transform:uppercase" onchange='return PanValidation(event)' id="txtPanNo" placeholder="Enter" />*@

    </div>


    <div class="col-md-1 mt-20">
        <button id="BtnSaveTradePricingDetails" class="btn btn-primary btn-fetch"><i class="fa fa-chevron-right"></i></button>
    </div>
    @*<div class="col-md-3 rblexisting" style="display:none" id="dv_clientId">
