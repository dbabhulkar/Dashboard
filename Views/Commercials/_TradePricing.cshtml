<div class="row form-group">
    <div class="col-md-12">
        <div class="custom_radio tradepricingcustomRadio" style="margin-left:0">
            <input type="radio" id="rbl_ntb" value="0" name="TradePriceType" checked=""><label for="rbl_ntb">NTB</label>
            <input type="radio" id="rbl_extisting" value="1" name="TradePriceType"><label for="rbl_extisting">Existing</label>

        </div>
    </div>
</div>

<div class="row form-group">
