                        <table class="responsive-table">
                            <thead>
                                <tr>
                                    <th>Customer Name</th>
                                    <th>Client ID</th>
                                    <th>Proposal Number</th>
                                    <th>RAROC (%)</th>
                                    <th>APR PFY (In Lacs)</th>
                                    <th>APR YTD (In Lacs)</th>
                                    <th>CTI (%)</th>
                                    <th>Vintage (In Years)</th>
