            <input type="text" class="form-control custom-form-control" style="text-transform:uppercase" id="AP_Approval_No" placeholder="Enter" />
            <p id="NTBApprovalNolength" style="display:none;color:red" class="label-control">Maximum 10 characters allowed</p>
        </div>
        <div class="col-md-1">
            <button id="btn_fetchIP_proposal" style="display:none" class="btn btn-primary btn-fetch"><i class="fa fa-chevron-right"></i></button>

        </div>


    </div>
