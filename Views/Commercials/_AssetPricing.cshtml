            <input type="text" onkeypress="return isNumberOnlyKey(event)" class="form-control custom-form-control" id="AP_ProposalNo" placeholder="Enter" />
            <p id="NTBProposalNolength" style="display:none;color:red" class="label-control">Maximum 12 characters allowed</p>
        </div>
        <div class="col-md-3" id="dv_ipApprovalNo" style="display:none">
