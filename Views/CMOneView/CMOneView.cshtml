                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row form-group">
                        <div class="col-md-12">
                            <div class="custom-card">
                                <div class="custom-card-body">
                                    <div class="custom-header-title">
                                        <h2>Delinquency</h2>
                                    </div>
                                    <table id="tbl_delinquency" class="display delinquency__tbl nowrap" style="width:100%;">
                                        <thead>
                                            <tr>
                                                <th>Account No.</th>
                                                <th>Customer name</th>
                                                <th>SME Client Id</th>
                                                <th>Date of TOD</th>
                                                <th>Curr Overdue AMT</th>
                                                <th>DPD</th>
                                                <th>Nature of delinquency</th>
                                                <th>Currency App PDO Loans Bills</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model.delinquencies != null)
                                            {
                                                @foreach (var item in Model.delinquencies)
                                                {
                                                    <tr>
                                                        <td>@item.AC_Contract_No</td>
                                                        <td>@item.Customer_Name</td>
                                                        <td>@item.SME_Client_ID</td>
                                                        <td>@item.DateOfTOD</td>
                                                        <td>@item.Curr_Overdue_AMT</td>
                                                        <td>@item.DPD</td>
                                                        <td>@item.Nature_of_Delq</td>
                                                        <td>@item.Currency_App_PDO_Loans_Bills</td>
                                                    </tr>
                                                }
                                            }
