@using Dashboard.Models
@model Dashboard.Models.OVIView;

@{
    ViewData["Title"] = "One View Indicator";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@*@Html.AntiForgeryToken()*@
@using (Html.BeginForm("CMOneView", "ProjectMaster"))
{
    <div class="wrapper">
        <div class="row form-group">

            <div class="col-md-12">
                <div class="dash-card">
                    <div class="row form-group">
                        <div class="col-md-5">
                            <label class="label-control">Enter Customer Name / LS ID</label>
                            <div class="txtContainer">
                                @Html.TextBoxFor(m => m.txt_custname, new { @class = "form-control custom-form-control" })
                                @if (Model.customerDetails != null)
                                {
                                    <a class="btn_remove_txtSearch"><i class="fa fa-times"></i></a>
                                }

                            </div>

                        </div>
                    </div>
                    <div class="row form-group">
                        <div class="col-md-6">
                            <div class="custom-card" style="margin-bottom:20px;">
                                <div class="custom-header-title">
                                    <div class="col-md-12">
                                        <h2>
                                            Customer Details
                                        </h2>
                                    </div>
                                </div>
                                <div class="custom-card-body">
                                    <div class="row">
                                        <div class="col-md-12" style="height:126px;overflow:auto">
                                            <table class="table table-borderless table-hover table-striped form-group chart-table cust-detail-table">
                                                <tr>
                                                    <th>Action</th>
                                                    <th>Customer Name</th>
                                                    <th>LSID</th>
                                                </tr>
                                                @if (Model.customerDetails != null)
                                                {
                                                    @foreach (var item in Model.customerDetails)
                                                    {
                                                        <tr>
                                                            <td>
                                                                @Html.ActionLink(
                                                                         linkText: "View",
                                                                         actionName: "CMOneView",
                                                                         controllerName: "CMOneView",
                                                                         routeValues: new { id = item.LSID, SearchText = item.CustomerName },
                                                                         htmlAttributes: new { @class = "btn btn-info" }
                                                                         )
                                                            </td>
                                                            <td>@item.CustomerName</td>
                                                            <td>@item.LSID</td>
                                                        </tr>
                                                    }
                                                }
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="custom-card">
                                <div class="custom-card-body">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <table class="table table-borderless table-hover table-striped form-group chart-table cust-detail-table">
                                                <tr>
                                                    <th>City</th>
                                                    <th>Region</th>
                                                    <th>LaserSoft ID</th>
                                                </tr>
                                                @if (Model.demographicReports != null)
                                                {
                                                    @foreach (var item in Model.demographicReports)
                                                    {
                                                        <tr>
                                                            <td>@item.City</td>
                                                            <td>@item.Region</td>
                                                            <td>@item.Lasersoft_Id</td>
                                                        </tr>
                                                    }
                                                }
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="custom-card">
                                <div class="custom-card-body">
