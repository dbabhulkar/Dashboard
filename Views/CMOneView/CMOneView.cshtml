                                                    <label class="label-control">Months</label>
                                                    @*<input type="text" id="months" class="form-control custom-form-control" disabled>*@
                                                    @Html.TextBoxFor(m => item.Pot_NPA_Months, new { @class = "form-control custom-form-control", @readonly = "true" })
                                                </div>

                                            </div>
                                        }
                                    }
