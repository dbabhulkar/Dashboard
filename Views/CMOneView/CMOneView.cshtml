                                <div class="custom-card-body">
                                    <table id="tbl_housekeeping" class="table table-borderless table-hover table-striped form-group chart-table cust-detail-table" style="width:100%;">
                                        <thead>
                                            <tr>
                                                <th>HouseKeeping Item </th>
                                                <th>Due Date</th>

                                            </tr>
                                        </thead>
                                        <tbody>
