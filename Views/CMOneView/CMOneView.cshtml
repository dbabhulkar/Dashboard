                                        <div class="col-md-12">
                                            <table class="table table-borderless table-hover table-striped form-group chart-table cust-detail-table">
                                                <tr>
                                                    <th>Facility</th>
                                                    <th>Limit</th>
                                                    <th>OS</th>
                                                    <th>AC Limit Set Date</th>
                                                    <th>Initial Limit Set Date</th>
                                                </tr>
                                                @if (Model.faciltyDtlReports != null)
