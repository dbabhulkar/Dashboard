@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor Accessor
@{
    ViewData["Title"] = "SelectionPage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: #f2f4f8;
        /*background-image:url(../../images/download.png);
                background-size:contain;
                background-repeat:no-repeat;
                background-position:center;*/
    }

    /*#overlay {
                position: fixed;
                width: 100%;
                height: 100%;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background-color: rgba(0,0,0,0.5);
                z-index: 2;
                cursor: pointer;
            }*/

    .quixnav, .header-content h1, .selection-login {
        display: none !important;
    }

    .content-body {
        margin-left: 0 !important;
    }

    .human-resources {
        --bg-color: #DCE9FF;
        --bg-color-light: #f1f7ff;
        --text-color-hover: #4C5656;
        --box-shadow-color: rgba(220, 233, 255, 0.48);
    }

    .card {
        width: 220px;
        height: 321px;
        background: #fff;
        border-top-right-radius: 10px;
        overflow: hidden;
        display: inline-block;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        position: relative;
        box-shadow: 0 14px 26px rgba(0,0,0,0.04);
        transition: all 0.3s ease-out;
        text-decoration: none;
        margin-right: 2%;
        margin-left: 2%;
    }

        .card:hover {
            transform: translateY(-5px) scale(1.005) translateZ(0);
            box-shadow: 0 24px 36px rgba(0,0,0,0.11), 0 24px 46px var(--box-shadow-color);
        }

            .card:hover .overlay {
                transform: scale(4) translateZ(0);
            }

            .card:hover .circle {
                border-color: var(--bg-color-light);
                background: var(--bg-color);
            }

                .card:hover .circle:after {
                    background: var(--bg-color-light);
                }

            .card:hover p {
                color: var(--text-color-hover);
                z-index: 10000000;
                position: relative;
                font-weight: 600;
            }

        .card:active {
            transform: scale(1) translateZ(0);
            box-shadow: 0 15px 24px rgba(0,0,0,0.11), 0 15px 24px var(--box-shadow-color);
        }

        .card p {
            font-size: 17px;
            color: #4C5656;
            margin-top: 100px;
            z-index: 1000;
            transition: color 0.3s ease-out;
            text-align: center;
        }

    .circle {
        width: 131px;
        height: 131px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid var(--bg-color);
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
        z-index: 1;
        transition: all 0.3s ease-out;
        left: 0;
        right: 0;
        margin: 0 auto;
        top: 70px;
    }

        .circle:after {
            content: "";
            width: 118px;
            height: 118px;
            display: block;
            position: absolute;
            background: var(--bg-color);
            border-radius: 50%;
            top: 5px;
            left: 5px;
            transition: opacity 0.3s ease-out;
        }

        .circle svg {
            z-index: 10000;
            transform: translateZ(0);
        }

        .circle i {
            z-index: 10000;
            transform: translateZ(0);
            font-size: 45px;
            color: #8888ff;
        }

        .circle img {
            z-index: 10000;
            transform: translateZ(0);
            font-size: 45px;
            color: #8888ff;
            width: 45px;
        }

    .overlay {
        width: 118px;
        position: absolute;
        height: 118px;
        border-radius: 50%;
        background: var(--bg-color);
        top: 70px;
        left: 50px;
        z-index: 0;
        transition: transform 0.3s ease-out;
    }

    .credentialing {
        --bg-color: #B8F9D3;
        --bg-color-light: #e2fced;
        --text-color-hover: #4C5656;
        --box-shadow-color: rgba(184, 249, 211, 0.48);
    }
</style>



<div class="container-fluid" style="text-align:center; transform: translate(0%, 50%);">
    <a href="#" class="card human-resources OVISection RMView">
        <div class="overlay"></div>
        <div class="circle">
            <img src="~/images/_347540600.svg" />

        </div>
        <p>RM View</p>
    </a>

    <a href="#" class="card human-resources OVISection CMView">
        <div class="overlay"></div>
        <div class="circle">
            <img src="~/images/_347540600.svg" />

        </div>
        <p>CM View</p>
    </a>

</div>

<script>

    $(".OVISection").click(function () {

        var sectionType = this.classList[3];

        SelectionProcess(sectionType);


    });

    function SelectionProcess(sectionType) {

        $.ajax({
            type: "POST",
            url: "/Login/SelectedPage",
            data: { "sectionType": sectionType },
            success: function (response) {
                if (response != null && response.isSuccess == 'false') {
                    //$("#lbl_message").text(response.msg);
                    toastr.error(response.msg);
                }
                else if (response != null && response.isSuccess == 'true') {
                    window.location.href = response.url;
                }

            },
            error: function (xhr, ajaxOptions, thrownError) {
                event.preventDefault();
            }
        });
    }

</script>