@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="wrapper">
    <div class="row form-group">
        <div class="col-md-12">
            <div class="dash-card">
                <h2 class="card-header-title">
                    To-do List
                </h2>
                <div class="card-header-right">
                    <ul class="to-do-status">
                        <li>
                            <div class="idication overdue"></div> Overdue
                        </li>
                        <li>
                            <div class="idication duesoon"></div> Due Soon
                        </li>
                        <li>
                            <div class="idication duelater"></div> Due Later
                        </li>
                    </ul>

                    @*@Html.ActionLink("View all", "#", null, null, new { @class = "link" })*@
                    <a href='@Url.Action("#","#")' class="link">View all <i class="fa fa-chevron-right"></i></a>
                </div>
                <div class="dash-card-body">
                    <div class="cust-table" style="padding: 5%;">
                        @*<table class="table table-borderless table-hover table-striped form-group">
                            <tr>
                                <th></th>
                                <th>Due On</th>
