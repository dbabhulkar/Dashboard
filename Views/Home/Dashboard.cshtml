    <!---  Bulletin Modal Popup ---->

    <div class="modal fade" id="bulletinModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content bulletin-content">
                <div class="modal-header bulletin-header">
                    <h5 class="modal-title bulletin-title" id="exampleModalLabel">Urgent Bulletins</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body bulletin-body">
                    <ul class="bulletin-list" id="bulletin_list"></ul>
                </div>

            </div>
        </div>
    </div>

    <div class="modal fade" id="ToDoModel" tabindex="-1" role="dialog" aria-labelledby="ToDoModel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content bulletin-content">
                <div class="modal-header bulletin-header">
                    <h5 class="modal-title bulletin-title" id="exampleModalLabel">ToDo List</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body bulletin-body">
                    <div class="cust-table">
                        <table class="table table-borderless table-hover table-striped form-group" id="tbl_all_todo">
                            <thead>
                                <tr>
                                    <th></th>
