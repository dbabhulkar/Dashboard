                                                    <td>0</td>
                                                </tr>
                                                <tr>
                                                    <td>Deferrals</td>
                                                    <td>0</td>
                                                </tr>
                                                <tr>
                                                    <td>IDPMS</td>
                                                    <td>0</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="col-md-4">
                                        <table class="table table-borderless table-striped table-hover compliance-table">
                                            <tbody>
                                                <tr>
                                                    <th>Item</th>
                                                    <th>No</th>
                                                </tr>
                                                <tr>
