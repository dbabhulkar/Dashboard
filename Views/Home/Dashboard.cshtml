                    <div class="portfolio-section">
                        <div style="padding:5px;">
                            <div class="row">
                                @{ var cnt = 0;
                                    var isInnerCount = false;
                                }

                                @if (compliance.Count > 0)
                                {

                                    @for (int i = 0; i < compliance.Count; i++)
                                    {
                                        if (cnt == 0)
                                        {
                                            @:<div class="col-md-4">
                                                @:<table class="table table-borderless table-striped table-hover compliance-table">
                                                    @:<tr>
                                                        @: <th>Item</th>
                                                        @: <th>No</th>
                                                    @:</tr>
                                                }
                                                //if (cnt != 0)
                                                //{
                                                <tr class="tooltipDashboard">
                                                    <td>@compliance[i].ComplianceItem</td>
                                                    <td>
                                                        @compliance[i].ItemCount
                                                        <span class="tooltiptext">@compliance[i].ItemDate</span>
                                                    </td>

                                                </tr>
                                                //}

                                                cnt = cnt + 1;
                                                if (cnt == 4 && !isInnerCount)
                                                {
                                                @:</table>
                                            @:</div>
                                            isInnerCount = true;
                                        }

                                        if (cnt == 4)
                                        {
                                            cnt = 0;
                                            isInnerCount = false;
                                        }
                                    }
                                    @if (!isInnerCount)
                                    {
                                        @:</table>
                                    @:</div>
                                }
                                }
                                @if (compliance.Count == 0)
